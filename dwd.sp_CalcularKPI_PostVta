	--SELECT * FROM dwd.KPI_PostVta WHERE indicadorKPI = 'ComA&I'
	INSERT INTO dwd.KPI_PostVta (
		-- Fechas
		fechaFactura
		,-- usamos FechaContable como fecha de factura
		mesaño
		,sucursalNombre
		,-- Info de sucursal / referencia / origen
		--sucursalNombre,
		importe
		,referencia
		,formadepago
		,descripcionOperativa
		,fcNumero
		,-- KPI
		indicadorKPI
		,KPIValue -- usamos el total como valor del KPI
		)
	SELECT C.FechaContable AS fechaFactura
		,CONCAT (
			YEAR(C.FechaContable)
			,'-'
			,RIGHT(CONCAT (
					'0'
					,MONTH(C.FechaContable)
					), 2)
			) AS mesaño
		,COALESCE(SDV.Nombre, 'ERROR SUCURSAL') AS sucursalNombre
		,-- <== ACÁ LA MAGIA
		CASE 
			WHEN C.Documento = 'NC'
				THEN C.Total * - 1
			ELSE C.Total
			END AS importe
		,C.Referencia
		,C.CondicionVenta AS formadepago
		,U.Descripcion AS descripcionOperativa
		,C.CONTROL AS fcNumero
		,'ComA&I' AS indicadorKPI
		,CASE 
			WHEN C.Documento = 'NC'
				THEN C.Total * - 1
			ELSE C.Total
			END AS KPIValue
	FROM sta.Comprobantes C
	LEFT OUTER JOIN sta.Movim m ON C.Asiento = M.MovNRO
	LEFT OUTER JOIN sta.UsuariosAccesos U ON U.usuariosAccesoID = M.MovUsuarioID
	LEFT OUTER JOIN sta.CentrosDeCostos CC ON CC.CentroID = C.CentroDeCosto
	LEFT OUTER JOIN sta.SucursalesContables SC ON C.Sucursal = SC.Numero
	LEFT JOIN sta.SucursalesDeventa SDV ON SDV.SucursalContableRepuestos = SC.Numero
	WHERE C.Origen = 'VTREP'
	and c.Fecha >= DATEADD(MONTH, -12, GETDATE()) -- 23ENE2026" para las fechas 

	
	


