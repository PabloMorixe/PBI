					IF OBJECT_ID('tempdb..#DetCashResumen') IS NOT NULL
						DROP TABLE #DetCashResumen;
			
							;

					WITH Grupos
					AS (
						SELECT CashID
							,CobranzaNro
							,MIN(CASE 
									WHEN Origen = 'VTREP'
										THEN Fecha
									END) AS FechaFactura
							,MAX(CASE 
									WHEN Origen = 'RC'
										THEN Fecha
									END) AS FechaRecibo
							,SUM(Importe) AS ImporteTotal
							,SUM(CASE 
									WHEN Origen = 'VTREP'
										THEN 1
									ELSE 0
									END) AS CantFacturas
							,SUM(CASE 
									WHEN Origen = 'RC'
										THEN 1
									ELSE 0
									END) AS CantRecibos
						FROM sta.DetCash
						WHERE Origen IN (
								'VTREP'
								,'RC'
								)
						GROUP BY CobranzaNro
							,CashID
						HAVING SUM(CASE 
									WHEN Origen = 'VTREP'
										THEN 1
									ELSE 0
									END) >= 1
							AND SUM(CASE 
									WHEN Origen = 'RC'
										THEN 1
									ELSE 0
									END) >= 1
							AND ABS(SUM(Importe)) < 1
						)
					SELECT dc.*
						,g.FechaFactura
						,g.FechaRecibo
						,DATEDIFF(DAY, g.FechaFactura, g.FechaRecibo) AS DiasEntreFacturaYUltimoRecibo
						,g.ImporteTotal
					INTO #DetCashResumen
					FROM sta.DetCash dc
					JOIN Grupos g ON dc.CashID = g.CashID
						AND dc.CobranzaNro = g.CobranzaNro
					WHERE dc.Origen IN (
							'VTREP'
							,'RC'
							)
					and dc.Fecha >= DATEADD(MONTH, -12, GETDATE()) -- 23ENE2026" para las fechas 


