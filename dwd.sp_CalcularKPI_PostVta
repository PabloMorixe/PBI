  -- Actualización: Se integra el importe de facturación (FC - NC) por cada Orden de Servicio.


-- 1. Definimos la suma de importes por Orden para evitar duplicados en el JOIN principal
;WITH ImportesPorOrden AS (
    SELECT 
        SODF.NumeroOrden,
        SODF.SucursalContable,
        SUM(CASE 
                WHEN C.Documento = 'NC' THEN C.Total * -1 
                ELSE C.Total 
            END) AS ImporteTotal
    FROM sta.ServiciosOrdenesDetalleFacturacion SODF WITH (NOLOCK)
    INNER JOIN sta.Comprobantes C WITH (NOLOCK) ON SODF.ComprobanteId = C.ComprobanteID
    WHERE C.Origen = 'VTSER'
    GROUP BY SODF.NumeroOrden, SODF.SucursalContable
)
INSERT INTO dwd.KPI_PostVta (
    FechaApertura,
    FechaCierre,
    mesaño,
    sucursalNombre,
    SucursalOrden,
    tipoCargo,
    tipoCargoDescripcion,
    gruposCodigo,
    gruposCodigoDescripcion,
    KPIValue,
    indicadorKPI,
    importe -- Nueva columna integrada
)
SELECT
    SO.Apertura AS FechaApertura,
    SO.Cierre AS FechaCierre,
    CONCAT(YEAR(SO.Apertura), '-', RIGHT(CONCAT('0', MONTH(SO.Apertura)), 2)) AS mesaño,
    SDV.Nombre AS sucursalNombre,
    CONCAT(RIGHT(CONCAT('0', SO.SucursalContable), 2), ' - ', SO.NumeroOrden) AS SucursalOrden,
    CAR.Tipodecargo AS tipoCargo,
    CAR.Descripcion AS tipoCargoDescripcion,
    G.Codigo AS gruposCodigo,
    G.Descripcion AS gruposCodigoDescripcion,
    CASE 
        WHEN DATEDIFF(DAY, SO.Apertura, SO.Cierre) = 0 THEN 1
        ELSE DATEDIFF(DAY, SO.Apertura, SO.Cierre)
    END AS KPIValue,
    'LeadTImeOrdenesCerradasXCargo' AS indicadorKPI,
    ISNULL(IPO.ImporteTotal, 0) AS importe
FROM sta.ServiciosOrdenes SO WITH (NOLOCK)
LEFT JOIN sta.Cargos CAR WITH (NOLOCK) 
    ON SO.Cargo = CAR.Codigo
LEFT JOIN sta.SucursalesDeVenta SDV WITH (NOLOCK) 
    ON SO.SucursalContable = SDV.Numero
LEFT JOIN sai..Grupos G WITH (NOLOCK) 
    ON SO.Grupo = G.Codigo
LEFT JOIN ImportesPorOrden IPO 
    ON SO.NumeroOrden = IPO.NumeroOrden 
    AND SO.SucursalContable = IPO.SucursalContable
WHERE
    -- Filtros de integridad de datos
    (SO.Apertura IS NOT NULL AND SO.Apertura <> '')
    AND (SO.Cierre IS NOT NULL AND SO.Cierre <> '')
    AND (SO.Cargo IS NOT NULL AND SO.Cargo <> '')
    -- Regla de Negocio: Solo órdenes cerradas para LeadTime
    AND SO.Cierre IS NOT NULL

	AND SO.Apertura >= DATEFROMPARTS(
                            YEAR(DATEADD(MONTH, -12, GETDATE())),
                            MONTH(DATEADD(MONTH, -12, GETDATE())),
                            1
                        )
    AND SO.Apertura < DATEFROMPARTS(
                            YEAR(DATEADD(MONTH, 1, GETDATE())),
                            MONTH(DATEADD(MONTH, 1, GETDATE())),
                            1
                        );





