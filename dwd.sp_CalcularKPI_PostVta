	--select * from dwd.KPI_PostVta where indicadorKPI = 'Preventas0KM+Accesorios'
	------------------------------------------------------------
	-- 1) Temp: Ventas de mostrador agrupadas por FACTURA
	------------------------------------------------------------
	IF OBJECT_ID('tempdb..#VentasMostradorAgrupadas') IS NOT NULL
		DROP TABLE #VentasMostradorAgrupadas;

	SELECT KTR.Referencia AS CodigoCliente
		,KTR.Documento
		,KTR.Fecha
		,SUM(KTR.Cantidad * KTR.Precio) AS ImporteTotalFactura
	INTO #VentasMostradorAgrupadas
	FROM sta.KardexTR KTR WITH (NOLOCK)
	INNER JOIN sta.Repuestos REP WITH (NOLOCK) ON KTR.Repuesto = REP.Codigo
		AND KTR.GestionID = REP.GestionID
	WHERE KTR.Tipo = 'E' -- Egresos
		AND SUBSTRING(KTR.Documento, 1, 2) = 'FC' -- Facturas
		AND REP.Familia IN (
			'ACCESORIO'
			,'INDUMENTARIA'
			,'CASCO'
			,'GADGET'
			,'ITEM'
			)
			and ktr.Fecha >= DATEADD(MONTH, -12, GETDATE()) -- 23ENE2026" para las fechas 

	GROUP BY KTR.Referencia
		,KTR.Documento
		,KTR.Fecha;

	------------------------------------------------------------
	-- 2) Temp: Resultado final (1 fila por preventa + postventa)
	------------------------------------------------------------
	IF OBJECT_ID('tempdb..#ResultadoPostVenta60d') IS NOT NULL
		DROP TABLE #ResultadoPostVenta60d;

	SELECT
		-- PREVENTA 0KM
		cli.codigo
		,PV.Fecha AS FechaVentaAuto
		,PV.Numero AS NroPreventa
		,SDV.Nombre AS Sucursal
		,CLI.Nombre AS ClienteNombre
		,MODL.DescripcionOperativa AS modelo
		,
		-- POSTVENTA (si existe dentro de 60 días)
		VM.Documento AS NroDocumentoPost
		,VM.Fecha AS FechaCompraPost
		,VM.ImporteTotalFactura AS ImportePost
		,
		-- MÉTRICAS
		DATEDIFF(DAY, PV.Fecha, VM.Fecha) AS DiasDesdeVentaAuto
		,CASE 
			WHEN VM.Documento IS NOT NULL
				THEN 1
			ELSE 0
			END AS ComproEnPostVenta_60d,

				CASE 
    WHEN u.UnidadTipo = 'E' THEN 'Especial'	
    WHEN u.UnidadTipo = 'P' THEN 'Propia'
    WHEN u.UnidadTipo = 'C' THEN 'Consignación'
    ELSE 'Otros' -- O puedes poner: ISNULL(UnidadTipo, 'Sin Definir')
