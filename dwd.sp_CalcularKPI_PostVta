/* KPI 58: Gestión de Turnos de PostVenta
   Responsable: SQL TABLEROS
   Descripción: Mapeo de turnos considerando la lógica polimórfica de Automotor.
*/
--------------------------------------------------------
-- KPI 58: Gestión de Turnos de PostVenta (CON LÓGICA DE FUTURO)
--------------------------------------------------------
--------------------------------------------------------------------------------------------------------------
--------------------------------------------------------------------------------------------------------------
--------------------------------------------------------------------------------------------------------------

INSERT INTO dwd.KPI_PostVta (
    mesaño,
    sucursalNombre,
    fechaFactura, 
    patente,
    ClienteNombre,
    referencia,   
    Modelo,
    KPIValue,           -- 1: Futuro, 0: Pasado
    cargoDescripcion,   -- Etiqueta de texto para filtros rápidos
    indicadorKPI,
	OrdenDeServicio
)
SELECT 
    -- Uso de FORMAT para consistencia en mesaño
    FORMAT(ST.Fecha, 'yyyy-MM') AS mesaño,
    ISNULL(SDV.Nombre, 'SIN SUCURSAL') AS sucursalNombre,
    ST.Fecha,
    ISNULL(NULLIF(ST.Patente, ''), 'A PATENTAR') AS patente,
    -- Limpieza de nombres de clientes
    LTRIM(RTRIM(
        CASE 
            WHEN ST.ClienteApellido IS NULL OR ST.ClienteApellido = '' THEN ST.ClienteNombre
            WHEN ST.ClienteNombre IS NULL OR ST.ClienteNombre = '' THEN ST.ClienteApellido
            ELSE ST.ClienteApellido + ', ' + ST.ClienteNombre
        END
    )) AS ClienteNombre,
 
 ST.Incidentes AS referencia,
 
 -- Lógica polimórfica según estándar de arquitectura
    CASE 
        WHEN ST.TablaAutomotor = 'ServiciosAutos' THEN SAMOD.DescripcionOperativa
        WHEN ST.TablaAutomotor = 'Unidades'       THEN UMOD.DescripcionOperativa
        WHEN ST.TablaAutomotor = 'Usados'         THEN USA.Marca + ' ' + USA.Modelo
        ELSE 'DESCONOCIDO'
    END AS Modelo,


    -- Lógica de KPIValue: Comparamos contra la fecha y hora actual
    CASE 
        WHEN ST.Fecha > GETDATE() THEN 1 
        ELSE 0 
    END AS KPIValue,





    -- Campo descriptivo para el usuario final
    CASE 
        WHEN ST.Fecha > GETDATE() THEN 'Turno Futuro' 
        ELSE 'Turno Pasado' 
    END AS cargoDescripcion,




    'TurnosPostVenta' AS indicadorKPI,
	

	    CASE 
        WHEN st.OrdenDeServicio  = 0 THEN 'Pendientes' 
        ELSE 'Tomado' 
    END AS OrdenDeServicio

	FROM sta.ServiciosTurnos ST WITH (NOLOCK)
	LEFT JOIN sta.Recepcionistas REC WITH (NOLOCK) 
		ON ST.RecepcionistaID = REC.RecepcionistaId
	LEFT JOIN sta.SucursalesDeventa SDV WITH (NOLOCK) 
		ON REC.Sucursal = SDV.Numero
	-- Cruce polimórfico condicional
	LEFT JOIN sta.ServiciosAutos SA WITH (NOLOCK) 
		ON ST.Automotor = SA.ServiciosAutosId AND ST.TablaAutomotor = 'ServiciosAutos'
	LEFT JOIN sta.Modelos SAMOD WITH (NOLOCK) 
		ON SA.Modelo = SAMOD.Modelo
	LEFT JOIN sta.Unidades U WITH (NOLOCK) 
		ON ST.Automotor = U.UnidadID AND ST.TablaAutomotor = 'Unidades'
	LEFT JOIN sta.Modelos UMOD WITH (NOLOCK) 
		ON U.Modelo = UMOD.Modelo
	LEFT JOIN sta.Usados USA WITH (NOLOCK) 
		ON ST.Automotor = USA.UsadoID AND ST.TablaAutomotor = 'Usados'
	WHERE ST.Fecha IS NOT NULL;


