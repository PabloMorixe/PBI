;wiTH MetricasVehiculo AS (
    SELECT 
        -- 1. Identificadores Base
        SO.SucursalContable,
        SDV.Nombre AS Sucursal,
        SO.NumeroOrden,
        SO.OrdenId,
        SO.Apertura AS FechaApertura,
        SO.Cierre AS FechaCierre,

        -- 2. Clasificación CORE (Propia vs Tercero)
        CASE 
            WHEN SO.TablaAutomotor = 'Unidades' THEN 'PROPIA'
            WHEN SO.TablaAutomotor = 'ServiciosAutos' THEN 'TERCERO'
            ELSE 'OTRO'
        END AS Origen_Unidad,

        -- 3. Datos del Vehículo (Normalizados)
        COALESCE(U.Patente, SA.Patente, 'S/PATENTE') AS Patente,
        COALESCE(O.Nombre, GT.Nombre, 'S/DATOS') AS Marca,
        COALESCE(MODL.Modelo, SA.Modelo, 'S/DATOS') AS Modelo,
        COALESCE(U.VIN, SA.VIN) AS VIN,
        FAM.Nombre AS Familia_Producto,

        -- 4. Cliente y Clasificación
        CLI.Nombre AS Cliente,
        CAR.Descripcion AS Cargo_Nombre,
        CAR.TipodeCargo AS Cargo_Tipo,
        
        -- NUEVA COLUMNA: Grupo
        G.Descripcion AS Grupo_Descripcion,

        -- 5. CÁLCULOS DE VENTANA (HISTORIAL DEL VEHÍCULO)
        -- Partition by TablaAutomotor + Automotor asegura que no mezclemos IDs de tablas distintas
        MIN(SO.Apertura) OVER (PARTITION BY SO.TablaAutomotor, SO.Automotor) AS FechaPrimerService,
        MAX(SO.Apertura) OVER (PARTITION BY SO.TablaAutomotor, SO.Automotor) AS FechaUltimoService,
        COUNT(SO.NumeroOrden) OVER (PARTITION BY SO.TablaAutomotor, SO.Automotor) AS Cantidad_Total_Visitas

    FROM sta.ServiciosOrdenes SO WITH (NOLOCK)
    
    -- Joins Estructurales
    LEFT JOIN sta.SucursalesDeventa SDV WITH (NOLOCK) ON SO.SucursalContable = SDV.Numero
    LEFT JOIN sta.Clientes CLI WITH (NOLOCK) ON SO.CodigoCliente = CLI.Codigo
    LEFT JOIN sta.Cargos CAR WITH (NOLOCK) ON SO.Cargo = CAR.Codigo
    LEFT JOIN sai..Grupos G WITH (NOLOCK) ON SO.Grupo = G.Codigo  -- Join para Grupo

    -- Rama A: Unidades Propias
    LEFT JOIN sta.Unidades U WITH (NOLOCK) ON SO.Automotor = U.UnidadID AND SO.TablaAutomotor = 'Unidades'
    LEFT JOIN sta.Modelos MODL WITH (NOLOCK) ON U.Modelo = MODL.Modelo
    LEFT JOIN sta.Origenes O WITH (NOLOCK) ON MODL.Origen = O.OrigenID
    LEFT JOIN sta.Familias FAM WITH (NOLOCK) ON MODL.Familia = FAM.FamiliaID

    -- Rama B: Unidades de Terceros
    LEFT JOIN sta.ServiciosAutos SA WITH (NOLOCK) ON SO.Automotor = SA.ServiciosAutosId AND SO.TablaAutomotor = 'ServiciosAutos'
    LEFT JOIN sta.Gestiones GT WITH (NOLOCK) ON SO.GestionID = GT.GestionID

    WHERE 
        SO.Cierre IS NOT NULL -- Solo órdenes cerradas
		and SO.Apertura >= DATEADD(MONTH, -12, GETDATE()) -- 23ENE2026" para las fechas 

)


			
