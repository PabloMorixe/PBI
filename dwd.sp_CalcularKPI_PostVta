--COMPLETA V1
select * from dwd.KPI_PostVta where indicadorKPI = 'ACont-LeadTime-fechafacturaRepuestosVsSaldocero'

									IF OBJECT_ID('tempdb..#DetCashResumen') IS NOT NULL
										DROP TABLE #DetCashResumen;
									
									-------------------

									;WITH Grupos AS (
										SELECT
											CashID,
											CobranzaNro,
											MIN(CASE WHEN Origen = 'VTREP' THEN Fecha END) AS FechaFactura,
											MAX(CASE WHEN Origen = 'RC'    THEN Fecha END) AS FechaRecibo,
											SUM(Importe) AS ImporteTotal,
											SUM(CASE WHEN Origen = 'VTREP' THEN 1 ELSE 0 END) AS CantFacturas,
											SUM(CASE WHEN Origen = 'RC'    THEN 1 ELSE 0 END) AS CantRecibos
										FROM sta.DetCash
										WHERE Origen IN ('VTREP','RC')
										GROUP BY CobranzaNro, CashID
										HAVING
											SUM(CASE WHEN Origen = 'VTREP' THEN 1 ELSE 0 END) >= 1
											AND SUM(CASE WHEN Origen = 'RC' THEN 1 ELSE 0 END) >= 1
											AND ABS(SUM(Importe)) < 1
									)
									SELECT
										dc.*,
										g.FechaFactura,
										g.FechaRecibo,
										DATEDIFF(DAY, g.FechaFactura, g.FechaRecibo) AS DiasEntreFacturaYUltimoRecibo,
										g.ImporteTotal
									INTO #DetCashResumen
									FROM sta.DetCash dc
									JOIN Grupos g
										  ON dc.CashID      = g.CashID
										 AND dc.CobranzaNro = g.CobranzaNro
									WHERE dc.Origen IN ('VTREP','RC');

									-------------------

									IF OBJECT_ID('tempdb..#DetCashResumenAgrupado') IS NOT NULL
										DROP TABLE #DetCashResumenAgrupado;

										-------------------
									SELECT
     
										dcr.CobranzaNro,
										dcr.Referencia,
										MIN(dcr.FechaFactura)                    AS FechaFactura,
										MAX(dcr.FechaRecibo)                     AS FechaRecibo,
										MIN(dcr.DiasEntreFacturaYUltimoRecibo)   AS DiasEntreFacturaYUltimoRecibo,
										SUM(dcr.Importe)                         AS ImporteTotalGrupo
									INTO #DetCashResumenAgrupado
									FROM #DetCashResumen dcr
									WHERE dcr.CobranzaNro <> ''
									 -- AND dcr.Referencia LIKE 'TR0000000001'
									GROUP BY
										dcr.CobranzaNro,
										dcr.Referencia;

										select * from #DetCashResumenAgrupado
