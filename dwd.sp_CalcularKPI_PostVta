	SELECT KTR.Fecha ,
		   KTR.Documento --FC NUMERO
	  ,
		   CONCAT(YEAR(KTR.Fecha), '-', RIGHT(CONCAT('0', MONTH(KTR.Fecha)), 2)) AS mesaño ,
		   KTR.Repuesto,
		   SDV.Nombre SucursalNombre ,
		   KTR.Precio ,
		   CLI.Nombre ,
		   REPLACE(REPLACE(REP.Descripcion, CHAR(13), ''), CHAR(10), '') AS Descripcion ,
		   KTR.Cantidad ,
		   rep.Familia ,
		   'VtaXTipoFamiliaProducto'
	FROM sta.KardexTR KTR
	LEFT OUTER JOIN sta.SucursalesDeventa SDV ON KTR.Sucursal = SDV.Numero
	LEFT OUTER JOIN sta.Clientes CLI ON KTR.Referencia = CLI.Codigo
	LEFT OUTER JOIN sta.Repuestos REP ON KTR.Repuesto = REP.Codigo
	AND KTR.GestionID = REP.GestionID
	WHERE (SUBSTRING(KTR.Documento, 1, 2) = 'FC')
	  AND KTR.Tipo = 'E'



