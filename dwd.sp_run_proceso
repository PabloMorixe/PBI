			WHEN LEFT(KTR.Documento, 2) = 'VA'
				THEN KTR.Cantidad
			ELSE - KTR.Cantidad
			END
		) * KTR.Precio * KTR.Cotizacion AS Monto
	,KTR.Costo * KTR.CotizacionCompra * (
		CASE 
			WHEN LEFT(KTR.Documento, 2) = 'VA'
				THEN KTR.Cantidad
			ELSE - KTR.Cantidad
			END
		) AS MontoCosto
	,KTR.Repuesto
	,REP.Descripcion AS DES
	,REC.Nombre AS Recepcionista
	,SO.Cierre
	,KTR.Documento
FROM sta.KardexTR AS KTR
LEFT OUTER JOIN sta.Cargos AS CAR ON KTR.Cargo = CAR.Codigo
LEFT OUTER JOIN sta.ServiciosOrdenes AS SO ON KTR.Orden = SO.NumeroOrden
	AND KTR.Sucursal = SO.SucursalContable
LEFT OUTER JOIN sta.Clientes AS CLI ON SO.CodigoCliente = CLI.Codigo
LEFT OUTER JOIN sta.Repuestos AS REP ON KTR.Repuesto = REP.Codigo
	AND KTR.GestionID = REP.GestionID
LEFT OUTER JOIN sta.Recepcionistas AS REC ON SO.Recepcionista = REC.Codigo
WHERE (KTR.Orden <> 0)) --2









UNION ALL



(SELECT SO.SucursalContable
	,so.Apertura as fechaApertura
	,CONCAT(YEAR(so.Apertura), '-', RIGHT(CONCAT('0', MONTH(so.Apertura)), 2)) AS mesaño
	,SO.NumeroOrden AS Orden
	,CLI.Codigo AS CodigoCliente
	,CLI.Nombre as ClinombreTerceros
	,3 AS Tipo
	,CAR.TipodeCargo
	,CAR.Codigo AS Cargo
	,CAR.Descripcion
	,SUM(SOD.Venta) AS Precio
	,1 AS Cant
	,SUM(SOD.Venta) AS Monto
	,SUM(SOD.Standard) AS MontoCosto
	,SOD.Codigo AS Repuesto
	,SER.Descripcion AS Des
	,REC.Nombre AS Recepcionista
	,SO.Cierre
	,CASE 
		WHEN SOD.ComprobanteFactura = ''
			THEN SOD.ComprobanteRemito
		ELSE SOD.ComprobanteFactura
		END AS Documento
FROM sta.ServiciosOrdenes AS SO
LEFT OUTER JOIN sta.Recepcionistas AS REC ON SO.Recepcionista = REC.Codigo
LEFT OUTER JOIN sta.ServiciosOrdenesDetalle AS SOD ON SO.SucursalContable = SOD.SucursalContable
	AND SO.NumeroOrden = SOD.NumeroOrden
LEFT OUTER JOIN sta.Clientes AS CLI ON SO.CodigoCliente = CLI.Codigo
LEFT OUTER JOIN sta.Servicios AS SER ON SOD.Codigo = SER.Codigo
LEFT OUTER JOIN sta.Cargos AS CAR ON SOD.Cargo = CAR.Codigo
WHERE (SER.OrigenServicio = 'T')
GROUP BY SOD.Codigo
	,so.apertura
	,SO.NumeroOrden
	,CAR.Descripcion
	,CAR.TipodeCargo
	,CLI.Codigo
	,CLI.Nombre  
	,SO.Cierre
	,SOD.Tipo
	,SER.Descripcion
	,SO.SucursalContable
	,CAR.Codigo
	,REC.Nombre
	,SOD.ComprobanteFactura
	,SOD.ComprobanteRemito
	)








UNION ALL
(SELECT SO.SucursalContable
	,SOD.Fecha as fechaOServicios
	,CONCAT(YEAR(SOD.Fecha), '-', RIGHT(CONCAT('0', MONTH(SOD.Fecha)), 2)) AS mesaño
	,SO.NumeroOrden AS Orden
	,CLI.Codigo AS CodigoCliente
	,CLI.Nombre 
	,2 AS Tipo
	,CAR.TipodeCargo
	,SODS.Cargo
	,CAR.Descripcion
	,SUM(SODS.VentaUnitario) AS Precio
	,SUM(SODS.TiempoaFacturar) AS Cant
	,SUM(SODS.TiempoaFacturar * SODS.VentaUnitario) AS Monto
	,SUM(SODS.TiempoEmpleado * SODS.CostoUnitario) AS MontoCosto
	,SOD.Codigo AS Repuesto
	,SER.Descripcion AS Des
	,REC.Nombre AS Recepcionista
	,SO.Cierre
	,SOD.ComprobanteFactura AS Documento
FROM sta.ServiciosOrdenes AS SO
LEFT OUTER JOIN sta.Recepcionistas AS REC ON SO.Recepcionista = REC.Codigo
LEFT OUTER JOIN sta.ServiciosOrdenesDetalle AS SOD ON SO.SucursalContable = SOD.SucursalContable
	AND SO.NumeroOrden = SOD.NumeroOrden
LEFT OUTER JOIN sta.ServiciosOrdenesDetalleDeServicios AS SODS ON SOD.ServiciosOrdenesDetalleId = SODS.IdServicio
LEFT OUTER JOIN sta.Cargos AS CAR ON SODS.Cargo = CAR.Codigo
LEFT OUTER JOIN sta.Servicios AS SER ON SODS.Servicio = SER.Codigo
LEFT OUTER JOIN sta.Clientes AS CLI ON SO.CodigoCliente = CLI.Codigo
WHERE (SER.OrigenServicio = 'P')
GROUP BY SOD.Codigo
	,SOD.Fecha
	,SO.NumeroOrden
	,SODS.Cargo
	,CAR.Descripcion
	,CAR.TipodeCargo
	,CLI.Codigo
	,CLI.Nombre 
	,SO.Cierre
	,SOD.Tipo
	,SER.Descripcion
	,SO.SucursalContable
	,REC.Nombre 
	,SOD.ComprobanteFactura) ) ot


LEFT OUTER JOIN tableros.sta.SucursalesDeventa sdv ON ot.[SucursalContable] = sdv.numero
)






