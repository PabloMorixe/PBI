SELECT * INTO [Tableros].[dwd].[Patentamientos1]
FROM (
    -- Nuevo Patentamientos 1
    SELECT 
		CONCAT(YEAR(pv.Fecha), '-', RIGHT(CONCAT('0', MONTH(pv.Fecha)), 2)) AS mesaño,
		SDV.NOMBRE as sucursalNombre,
        PV.Fecha,
        PV.Numero,
        CLI.Nombre as clienteNombre,
        M.Modelo,
        V.Nombre AS Vendedor,
        PV.PrecioVenta,
        COALESCE(View_GXP.TotalGasto, 0) AS TotalGastosPV,
        COALESCE(View_GXP.TotalGasto, 0) + PV.PrecioVenta AS TotalPV,
        PV.CotizacionDolar,
        COL.Descripcion AS Color,
        U.IDFabrica,
        F.Nombre AS Familia,
        M.DescripcionOperativa,
        SUM(T_GXP.Importe) AS Total,
        MAX(CON.Nombre) AS NombreConcepto,
        MAX(CON.Cuenta) AS CuentaConcepto,
        MAX(C.CONTROL) AS ControlComprobante
    FROM sta.Preventas PV
    LEFT OUTER JOIN sta.GastoXPrevta T_GXP ON T_GXP.PrevtaID = PV.PrevtaID
    LEFT OUTER JOIN sta.Comprobantes C ON C.CONTROL = T_GXP.Factura
    LEFT OUTER JOIN sta.Conceptos CON ON CON.ConceptoID = T_GXP.GastoID
    LEFT OUTER JOIN sta.Clientes CLI ON CLI.Codigo = PV.Cliente
    LEFT OUTER JOIN sta.SucursalesDeventa SDV ON SDV.Numero = PV.Sucursal
    LEFT OUTER JOIN sta.Modelos M ON M.Modelo = PV.Modelo
    LEFT OUTER JOIN sta.Familias F ON F.FamiliaID = M.Familia
    LEFT OUTER JOIN sta.Vendedores V ON V.VendedorId = PV.VendedorID
    LEFT OUTER JOIN sta.GastosPorPreventa View_GXP ON View_GXP.PrevtaID = PV.PrevtaID
    LEFT OUTER JOIN sta.Colores COL ON COL.ColorID = PV.ColorID
    LEFT OUTER JOIN sta.Unidades U ON U.Preventa = PV.Numero
    WHERE CON.ConceptoID IN (204, 205)
        AND PV.Anulada = 0
    GROUP BY 
        SDV.NOMBRE,
        PV.Fecha,
        PV.Numero,
        CLI.Nombre,
        M.Modelo,
        V.Nombre,
        PV.PrecioVenta,
        View_GXP.TotalGasto,
        PV.CotizacionDolar,
        COL.Descripcion,
        U.IDFabrica,
        F.Nombre,
        M.DescripcionOperativa
    HAVING SUM(T_GXP.Importe) >= 1
) AS Patentamientos1;


