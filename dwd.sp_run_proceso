        NULL AS IDFabrica,
        USA.Marca AS Familia,
        USA.VIN AS VIN,
        PV.PrecioSugerido AS PrecioSugerido,
        'Usados' AS TipoEntrega
    FROM sta.Preventas_SAI_CAJA PV
    LEFT JOIN sta.SucursalesDeVenta_SAI_CAJA SDV ON SDV.Numero = PV.Sucursal
