        WHEN [NombreSucursal] IN ('ROYAL ENFIELD VTE. LOPEZ', 'Royal Enfield FCE 0km VL', 'Royal Enfield 0 Km VL', 'Royal Enfield Postventa VL','Royal Enfield FCE Postventa') THEN 'Royal Enfield Vicente Lopez'
        WHEN [NombreSucursal] IN ('NUUV PALERMO', 'Nuuv Palermo Accesorios', 'Nuuv Palermo 0km') THEN 'Nuuv Palermo'
