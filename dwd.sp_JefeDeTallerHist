--B1--------------------------------------------------- TALLER CARGO CLIENTE-Ordenes Cerradas Facturadas Cargo Cliente Q y $
INSERT INTO dwd.StoreManager_JefeTallerHist (
    fecha,
	SucursalOrden,                  
    sucursalNombre,   
	referencia,
   -- PVNumero,                
    importe,                 
 --   referencia,              
  --  descripcionOperativa,    
    indicador
	                
)
--Ordenes Cerradas Facturadas Cargo Cliente Q y $ :
SELECT
    C.FechaContable, --fecha
     VSUC.NumeroOrden, --sucucursal-Orden
	CASE 
    WHEN C.FacturaDeCredito = 0 THEN SDV.nombre 
    ELSE SDVFCE.Nombre
    END AS sucursalNombre, --sucursalNombre
	C.Control, --Referencia
    CASE 
    WHEN C.Documento = 'NC' THEN C.Total * -1
    ELSE C.Total
    END AS IMPORTE, --importe
    'TALLER CARGO CLIENTE-Ordenes Cerradas Facturadas Cargo Cliente Q y $' as indicador
  

FROM SAI.dbo.Comprobantes C
LEFT OUTER JOIN SAI.dbo.Movim m
    ON C.Asiento = M.MovNRO
LEFT OUTER JOIN SAI.dbo.UsuariosAccesos U
    ON U.usuariosAccesoID = M.MovUsuarioID
LEFT OUTER JOIN SAI.dbo.SucursalesContables SC ON C.Sucursal=SC.Numero
LEFT OUTER JOIN SAI.dbo.SucursalesDeventa SDV ON C.Sucursal=SDV.SucursalContableServicios
LEFT OUTER JOIN SAI.dbo.SucursalesDeventa SDVFCE ON C.Sucursal=SDVFCE.SucursalContableServiciosFCE
LEFT OUTER JOIN
(SELECT        STA.ServiciosOrdenesDetalleFacturacion.NumeroOrden, MAX(STA.Comprobantes.ComprobanteID) AS [ID Comprobante], STA.Comprobantes.Origen, 
                         STA.ServiciosOrdenesDetalleFacturacion.SucursalContable
FROM            STA.Comprobantes INNER JOIN
                         STA.ServiciosOrdenesDetalleFacturacion ON STA.Comprobantes.ComprobanteID = STA.ServiciosOrdenesDetalleFacturacion.ComprobanteId
WHERE        (STA.Comprobantes.Origen = 'VTSER')
GROUP BY STA.Comprobantes.Origen, STA.ServiciosOrdenesDetalleFacturacion.NumeroOrden, STA.ServiciosOrdenesDetalleFacturacion.SucursalContable) AS VSUC ON C.ComprobanteID=VSUC.[ID Comprobante]

WHERE     C.Origen = 'VTSER'
--B2--------------------------------------------------- TALLER CARGO CLIENTE-Ordenes sin cerrar Q y $

IF OBJECT_ID('tempdb..#Temp') IS NOT NULL
    DROP TABLE #Temp;

-- Primero, insertamos los datos en la tabla temporal
WITH BaseDatos AS (
    -- Servicios Propios
    SELECT
        SO.SucursalContable,
        SO.Apertura,
        SO.Cierre,
        CONCAT(RIGHT(CONCAT('0', SO.SucursalContable), 2), ' - ', SO.NumeroOrden) AS SucursalOrden,
        'Servicios Propios' AS Tipo,
        CAR.TipodeCargo,
        SUM(SODS.TiempoaFacturar * SODS.VentaUnitario) AS Monto
    FROM sta.ServiciosOrdenes AS SO
    LEFT OUTER JOIN sta.ServiciosOrdenesDetalle AS SOD 
        ON SO.SucursalContable = SOD.SucursalContable AND SO.NumeroOrden = SOD.NumeroOrden
    LEFT OUTER JOIN sta.ServiciosOrdenesDetalleDeServicios AS SODS 
        ON SOD.ServiciosOrdenesDetalleId = SODS.IdServicio
    LEFT OUTER JOIN sta.Cargos AS CAR 
        ON SODS.Cargo = CAR.Codigo
    LEFT OUTER JOIN sta.Servicios AS SER 
        ON SODS.Servicio = SER.Codigo
    WHERE (SER.OrigenServicio = 'P')
    GROUP BY SO.SucursalContable, SO.Apertura, SO.Cierre, SO.NumeroOrden, CAR.TipodeCargo

    UNION ALL

    -- Servicios Terceros
    SELECT
        SO.SucursalContable,
        SO.Apertura,
        SO.Cierre,
        CONCAT(RIGHT(CONCAT('0', SO.SucursalContable), 2), ' - ', SO.NumeroOrden) AS SucursalOrden,
        'Servicios Terceros' AS Tipo,
        CAR.TipodeCargo,
        SUM(SOD.Venta) AS Monto
    FROM sta.ServiciosOrdenes AS SO
    LEFT OUTER JOIN sta.ServiciosOrdenesDetalle AS SOD 
        ON SO.SucursalContable = SOD.SucursalContable AND SO.NumeroOrden = SOD.NumeroOrden
    LEFT OUTER JOIN sta.Servicios AS SER 
        ON SOD.Codigo = SER.Codigo
    LEFT OUTER JOIN sta.Cargos AS CAR 
        ON SOD.Cargo = CAR.Codigo
    WHERE (SER.OrigenServicio = 'T')
    GROUP BY SO.SucursalContable, SO.Apertura, SO.Cierre, SO.NumeroOrden, CAR.TipodeCargo

    UNION ALL

    -- Repuestos
    SELECT
        SO.SucursalContable,
        SO.Apertura,
        SO.Cierre,
        CONCAT(RIGHT(CONCAT('0', SO.SucursalContable), 2), ' - ', KTR.Orden) AS SucursalOrden,
        'Repuestos' AS Tipo,
        CAR.TipodeCargo,
        SUM((CASE WHEN LEFT(KTR.Documento, 2) = 'VA' THEN KTR.Cantidad ELSE (-1) * KTR.Cantidad END) * KTR.Precio * KTR.Cotizacion) AS Monto
    FROM sta.KardexTR AS KTR
    LEFT OUTER JOIN sta.Cargos AS CAR 
        ON KTR.Cargo = CAR.Codigo
    LEFT OUTER JOIN sta.ServiciosOrdenes AS SO 
        ON KTR.Orden = SO.NumeroOrden AND KTR.Sucursal = SO.SucursalContable
    WHERE (KTR.Orden <> 0)
    GROUP BY SO.SucursalContable, SO.Apertura, SO.Cierre, KTR.Orden, CAR.TipodeCargo
)
SELECT
    CONCAT(YEAR(BD.Apertura), '-', RIGHT(CONCAT('0', month(BD.Apertura)), 2)) AS mesaño,
    BD.SucursalContable as sucursalNumero,
    SDV.Nombre as sucursalNombre, 
    BD.SucursalOrden,
    BD.Apertura,
    BD.Cierre,
    COALESCE(SUM(CASE WHEN BD.Tipo = 'Repuestos' THEN BD.Monto ELSE 0 END), 0) AS MontoTotalRepuestos,
    COALESCE(SUM(CASE WHEN BD.Tipo = 'Servicios Propios' THEN BD.Monto ELSE 0 END), 0) AS MontoTotalServiciosPropios,
    COALESCE(SUM(CASE WHEN BD.Tipo = 'Servicios Terceros' THEN BD.Monto ELSE 0 END), 0) AS MontoTotalServiciosTerceros,
    BD.TipodeCargo
INTO #Temp  -- Aquí creamos e insertamos en la tabla temporal
FROM BaseDatos BD
LEFT OUTER JOIN sta.SucursalesDeventa SDV ON BD.SucursalContable=SDV.Numero
WHERE BD.TipodeCargo = 'Cliente' and BD.Cierre IS NULL
GROUP BY BD.SucursalOrden, BD.Apertura, BD.Cierre, BD.TipodeCargo, BD.SucursalContable, SDV.Nombre
ORDER BY BD.SucursalOrden;

-- Ahora sí podemos insertar desde #Temp
