    MontoTotalServiciosTerceros,
    (ISNULL(MontoTotalRepuestos, 0) + ISNULL(MontoTotalServiciosPropios, 0) + ISNULL(MontoTotalServiciosTerceros, 0)),
    'TALLER CARGO CLIENTE-Ordenes sin cerrar Q y $'
FROM #Temp;

