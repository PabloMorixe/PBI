(
    fecha,
    sucursalNombre,
	Modelo
	-- Si necesitas agregar una sucursal por defecto, utiliza un valor constante
    ,origen,
    descripcionOperativa,
    color,
    unidadTipo,
    ubicacion, 
	indicador,
	IDFabrica
)
SELECT 
	u.FechaDePedido
    ,sdv.nombre      -- Placeholder para sucursal (ajustar si es necesario)
	,MODL.Modelo
   ,O.Nombre AS ORIGEN
		,MODL.descripcionOperativa
		,COL.Descripcion AS COLOR
		 ,u.UnidadTipo
		 ,UBI.Descripcion
	,'0KM-stock disponible 0KM a recibir - sin reserva sin preventa Q' 
	,u.idfabrica
FROM 
    sta.Unidades U
LEFT OUTER JOIN sta.Colores COL ON U.Color = COL.ColorID
LEFT OUTER JOIN sta.Ubicaciones UBI ON U.Ubicacion = UBI.UbicacionID
