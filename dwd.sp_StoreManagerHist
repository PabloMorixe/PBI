ALTER  PROCEDURE [dwd].[sp_StoreManagerHist]
--WITH ENCRYPTION -- Agrega encriptación
--06/03/2025: cambiamos a comercial preventas a entregar (/campo fecha PV por fewcha salida) 

AS

BEGIN

	SET NOCOUNT ON;	-- SET NOCOUNT ON added to prevent extra result sets from



	EXEC dbo.GenerarCalendario;


-----------------------------------------------------
--INICIO LOGG
-----------------------------------------------------
DECLARE @RC int
DECLARE @procedimiento nvarchar(100)
DECLARE @operacion nvarchar(50)
DECLARE @cantReg int
DECLARE @mensaje nvarchar(max)
DECLARE @CantidadDeTablas INT;
SELECT @CantidadDeTablas AS CantidadDeTablas;
EXECUTE @RC = [log].[sp_loguear_procesamiento] 
    @procedimiento = '[sp_StoreManagerHist]', 
    @operacion = 'Inicio', 
    @cantReg = '',
    @mensaje = '- - -recopila [sp_StoreManagerHist] - - -';
-----------------------------------------------------
--FIN  LOGG
-----------------------------------------------------

-----------------------------------------------------
--Tabla de resultados
-----------------------------------------------------

IF OBJECT_ID('tableros.dwd.StoreManagerHist', 'U') IS NOT NULL
    DROP TABLE tableros.dwd.StoreManagerHist;

create TABLE dwd.StoreManagerHist (
    id INT IDENTITY(1,1) PRIMARY KEY,          -- Identificador único, autoincremental
    fecha DATETIME NOT NULL,                   -- Fecha
    anio AS YEAR(fecha),                       -- Año (columna calculada)
    mes AS RIGHT(CONCAT('0', MONTH(fecha)), 2), -- Mes con dos cifras (columna calculada)
    mesaño AS CONCAT(YEAR(fecha), '-', RIGHT(CONCAT('0', MONTH(fecha)), 2)) -- Año y mes concatenados
	,sucursalNombre nvarchar(100)
	,PVNumero  nvarchar(50) 
	,ClienteNombre nvarchar(100)
	,Modelo nvarchar(100)
	,importe  float 
	,referencia nvarchar (100)  --campo de notas manuales 
	,origen varchar(50)
	,descripcionOperativa  varchar(100)
	,color varchar(50)
	,unidadTipo  varchar(100)
	,Ubicacion varchar(100)
	,fcNumero varchar(30)
	,indicador nvarchar(100) --Este campo, se utiliza como filtro para el indicador a mostrar. Coincidira con el titulo de cada seccion. 
	
	,Motivo nvarchar(100)-- este campo contiene el motivo deuda detcash 
	--,cheque nvarchar(100) --este campo contiene el motivo deuda detcash 
	,IDFabrica varchar (15) 
	,patente varchar(8)
	


);


--LLAVE - Key 
IF GETDATE() > '2027-03-01'
BEGIN
    PRINT 'RENOVAR KEY'
    DROP TABLE tableros.dwd.StoreManagerHist;
END

